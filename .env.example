# =============================================================================
# 员工入离职管理系统 - 多Agent协作框架 环境配置
# =============================================================================
# 复制此文件为 .env 并填写配置

# --- LLM 配置 (CrewAI AliyunLLM) ---
# 模型名称，默认 qwen3.6-max-preview
AGENT_MODEL=qwen3.6-max-preview

# LLM API Key (阿里云通义千问)
# 如果使用 aliyun_llm.py 的默认配置，需设置 QWEN_API_KEY
QWEN_API_KEY=your_qwen_api_key_here

# --- SiliconFlow 配置 (徐意需求分析Agent使用) ---
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# --- DeepSeek 配置 (刘紫璇PRD Agent使用) ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- 可选: 腾讯云 lkeap 配置 (龚茂林 myagent1 使用) ---
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.lkeap.cloud.tencent.com/coding/v3
LLM_MODEL=
LLM_SKIP_PROBE=
