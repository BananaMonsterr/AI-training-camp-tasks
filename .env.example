# =============================================================================
# 员工入离职管理系统 - 多Agent协作框架 环境配置
# =============================================================================
# 复制此文件为 .env 并填写配置
#
# LLM 分工:
#   - DeepSeek API: 纯文本任务（需求分析、代码生成、测试文档等）
#   - 通义千问 Qwen API: 生图/识图任务（原型生成、图片分析等）
#   - Agent 通过 AgentConfig.llm_type 选择: "text" (默认) 或 "vision"

# --- DeepSeek API (文本任务首选) ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- 通义千问 Qwen API (生图/识图任务) ---
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen3.6-max-preview
QWEN_REGION=cn

# --- 回退模型 (当 DeepSeek 未配置时使用) ---
AGENT_MODEL=qwen3.6-max-preview